SQLite Schema
sql-- Every file ever seen on the iPhone
CREATE TABLE files (
  id              INTEGER PRIMARY KEY AUTOINCREMENT,
  device_id       TEXT NOT NULL,          -- iPhone UDID
  relative_path   TEXT NOT NULL,          -- e.g. DCIM/100APPLE/IMG_0001.HEIC
  filename        TEXT NOT NULL,
  size_bytes      INTEGER NOT NULL,
  file_modified   TEXT,                   -- ISO date from filesystem
  exif_date       TEXT,                   -- EXIF DateTimeOriginal
  exif_gps_lat    REAL,
  exif_gps_lon    REAL,
  media_type      TEXT,                   -- 'photo' | 'video' | 'unknown'
  mime_type       TEXT,
  width           INTEGER,
  height          INTEGER,
  duration_sec    REAL,                   -- for videos
  source_hash     TEXT,                   -- xxhash of source file
  first_seen_at   TEXT NOT NULL,
  UNIQUE(device_id, relative_path)
);

-- Every copy operation attempted
CREATE TABLE copy_records (
  id               INTEGER PRIMARY KEY AUTOINCREMENT,
  file_id          INTEGER NOT NULL REFERENCES files(id),
  job_id           INTEGER NOT NULL REFERENCES backup_jobs(id),
  dest_path        TEXT NOT NULL,         -- full absolute destination path
  dest_folder      TEXT NOT NULL,         -- the chosen destination folder root
  status           TEXT NOT NULL,         -- 'pending' | 'copying' | 'done' | 'failed' | 'skipped'
  bytes_copied     INTEGER DEFAULT 0,
  error_message    TEXT,
  started_at       TEXT,
  finished_at      TEXT,
  dest_hash        TEXT,                  -- xxhash computed after copy for verification
  verified         INTEGER DEFAULT 0,     -- 1 if source_hash == dest_hash
  UNIQUE(file_id, dest_folder)            -- one record per file per destination
);

-- Backup job sessions
CREATE TABLE backup_jobs (
  id               INTEGER PRIMARY KEY AUTOINCREMENT,
  device_id        TEXT NOT NULL,
  dest_folder      TEXT NOT NULL,
  status           TEXT NOT NULL,         -- 'running' | 'paused' | 'completed' | 'cancelled' | 'failed'
  total_files      INTEGER DEFAULT 0,
  copied_files     INTEGER DEFAULT 0,
  skipped_files    INTEGER DEFAULT 0,
  failed_files     INTEGER DEFAULT 0,
  total_bytes      INTEGER DEFAULT 0,
  copied_bytes     INTEGER DEFAULT 0,
  started_at       TEXT NOT NULL,
  paused_at        TEXT,
  resumed_at       TEXT,
  finished_at      TEXT,
  error_log        TEXT                   -- JSON array of error objects
);

CREATE INDEX idx_files_device ON files(device_id);
CREATE INDEX idx_copy_records_job ON copy_records(job_id);
CREATE INDEX idx_copy_records_status ON copy_records(status);
CREATE INDEX idx_copy_records_file_dest ON copy_records(file_id, dest_folder);

IPHONE DETECTION & MOUNTING (macOS)
Prerequisites Check (run on app startup)
1. Check if macFUSE is installed: system_profiler SPExtensionsDataType | grep macFUSE
2. Check if ifuse is installed: which ifuse
3. Check if ideviceinfo is installed: which ideviceinfo
4. If any missing → show setup guide in UI with brew install commands
Device Detection

Poll idevice_id -l every 3 seconds to detect connected iPhones
On detection: run ideviceinfo -u <UDID> to get device name, iOS version, serial
Emit WebSocket event device:connected with device info
On disconnect: emit device:disconnected

Mounting Flow
1. Create mount point: mkdir -p ~/VaultSync/mounts/<UDID>
2. Check if already mounted: mount | grep <mount_point>
3. If mounted: verify it's accessible (ls the mount point)
4. If not mounted: run ifuse --udid <UDID> ~/VaultSync/mounts/<UDID>
5. After mount: read DCIM folder to count total files
6. Emit WebSocket: mount:success with { mountPath, fileCount, deviceName }
Unmounting
1. Wait for any active copy operations to complete current file
2. run: umount ~/VaultSync/mounts/<UDID>  (NOT fusermount on macOS)
3. Emit: mount:disconnected
Error Cases for iPhone

Trust not accepted → parse ifuse error, show "Unlock iPhone and tap Trust"
Already mounted but inaccessible → auto unmount + remount
iPhone locked during copy → pause copy, wait for unlock signal, resume
USB cable disconnected mid-copy → detect via idevice_id -l poll, mark current file as failed, save job state, notify UI


